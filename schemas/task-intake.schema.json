{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forneus.io/schemas/kairos/task-intake.schema.json",
  "title": "KAIROS Task Intake",
  "type": "object",
  "required": ["task_id", "created_at", "requester", "summary", "data_sensitivity", "intended_action"],
  "properties": {
    "task_id": {
      "type": "string",
      "description": "Stable local identifier for the task."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "requester": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "data_sensitivity": {
      "type": "string",
      "enum": ["public", "internal", "confidential", "restricted"]
    },
    "intended_action": {
      "type": "string",
      "enum": ["draft", "analyze", "classify", "recommend", "send", "change_record", "external_call"]
    },
    "external_destination": {
      "type": "string"
    },
    "requires_attachment": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
